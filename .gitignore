# KAIROS — .gitignore

# Imagens temporárias — nunca entram no repo
audit_*.png
audit_*.jpg
screenshot_*.png
kairos_thumbnail*.png
s[123]_candidate*.jpg
S[123]_*.png
ph_s*.png

# Runtime data (never commit)
.kairos-data/
*.log

# Vault (NEVER commit)
.kairos-vault/
vault.enc
*.key
*.pem

# Environment
.env
.env.*
!.env.example

# Node
node_modules/

# PM2
.pm2/

# OS
.DS_Store
Thumbs.db

# Temp
landing-preview.html
kairos-novo.html
kairos-v8.html
kairos-tesla.html

# Backup volumes locais
.backup-volume/

# Inventários gerados (regenerar via inventory-agent)
estrutura.txt
ficheiros.csv
inventario.txt
/inventory-*.txt
/inventory-*.csv
packages/web/node_modules
packages/web/.next

.vercel

.ai/design-ref/
