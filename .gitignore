# KAIROS — .gitignore

# Imagens temporárias — nunca entram no repo
audit_*.png
audit_*.jpg
screenshot_*.png
kairos_thumbnail*.png
s[123]_candidate*.jpg
S[123]_*.png
ph_s*.png

# Runtime data (never commit)
.kairos-data/
*.log

# Vault (NEVER commit)
.kairos-vault/
vault.enc
*.key
*.pem

# Environment
.env
.env.*
!.env.example

# Node
node_modules/

# TypeScript incremental build cache
.tsbuildinfo

# PM2
.pm2/

# OS
.DS_Store
Thumbs.db

# Temp
landing-preview.html
kairos-novo.html
kairos-v8.html
kairos-tesla.html

# Backup volumes locais
.backup-volume/

# Inventários gerados (regenerar via inventory-agent)
estrutura.txt
ficheiros.csv
inventario.txt
/inventory-*.txt
/inventory-*.csv
packages/web/node_modules
packages/web/.next

.vercel

.ai/design-ref/
.claude/memory/snapshots/
.claude/memory/state-ledger.jsonl
.claude/.consensus-key
*.tmp

# Environment & Secrets (AIOX)
.env.local
.env.*.local

# Dependencies (AIOX)
node_modules

# Build & Logs (AIOX)
dist/
build/
logs/

# IDE & OS (AIOX)
.idea/
*.swp

# AIOX Local (AIOX)
.aiox-core/local/
.claude/settings.local.json
.aiox/install-log.txt

# Agent-context cache (Story 12.3 — per-session, regenerated on activation)
.aiox/.agent-context-cache.json

# Claude Code logs (gerados automaticamente)
.claude/logs/

# VS Code workspace files (não pertencem ao repo)
*.code-workspace
.claude/agents/*.code-workspace

# Backups automáticos (nunca entram no repo)
*.backup.*

# Gate decision logs (runtime, regenerados pelos hooks)
.aiox/gate-logs/*.jsonl
