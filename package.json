{
  "name": "kairos-cerebro",
  "version": "0.1.0",
  "private": true,
  "description": "Kairos Check — OSINT fraud scoring API",
  "bin": {
    "kairos": "bin/kairos.js"
  },
  "scripts": {
    "dev": "npx aiox-core",
    "start": "node bin/kairos.js start",
    "start:server": "node packages/sniper-api/server.js",
    "backup": "node bin/backup-volume.js",
    "test": "node --test --test-concurrency=1 packages/sniper-api/*.test.js tests/hooks/*.test.js tests/ids/*.test.js tests/auto-contextualization/**/*.test.js tests/context-registry/*.test.js tests/immortality/*.test.js tests/framework/*.test.js && npm run test:ws",
    "test:ws": "node --import tsx --test tests/websocket/Broadcaster.test.ts",
    "audit:verify": "node bin/kairos.js audit:verify",
    "compliance:purge": "node bin/kairos.js compliance:purge",
    "lint": "eslint .claude/hooks .aiox/task-discovery.js tests/hooks --quiet",
    "lint:all": "eslint .",
    "build": "npm run typecheck",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "sync:ide:claude": "node .aiox-core/infrastructure/scripts/ide-sync/index.js sync --ide claude-code",
    "validate:claude-sync": "node .aiox-core/infrastructure/scripts/ide-sync/index.js validate --ide claude-code",
    "validate:claude-integration": "node .aiox-core/infrastructure/scripts/validate-claude-integration.js",
    "prepare": "husky"
  },
  "dependencies": {
    "ajv-formats": "^3.0.1",
    "dotenv": "^17.4.2",
    "js-yaml": "^4.3.0",
    "resend": "^6.12.3",
    "stripe": "^16.0.0",
    "ws": "^8.21.0",
    "yaml": "^2.9.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "@clack/prompts": "^1.6.0",
    "@eslint/js": "^10.0.1",
    "@kayvan/markdown-tree-parser": "^1.6.1",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "ansi-to-html": "^0.7.2",
    "asciichart": "^1.5.25",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "cli-progress": "^3.12.0",
    "commander": "^15.0.0",
    "eslint": "^10.4.1",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.6",
    "glob": "^13.0.6",
    "handlebars": "^4.7.9",
    "inquirer": "^14.0.2",
    "node-machine-id": "^1.1.12",
    "ora": "^9.4.1",
    "picocolors": "^1.1.1",
    "proper-lockfile": "^4.1.2",
    "semver": "^7.8.5",
    "tsx": "^4.22.4",
    "validator": "^13.15.35"
  }
}
