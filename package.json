{
  "name": "kairos-cerebro",
  "version": "0.1.0",
  "private": true,
  "description": "Kairos Check — OSINT fraud scoring API",
  "bin": {
    "kairos": "bin/kairos.js"
  },
  "scripts": {
    "start": "node bin/kairos.js start",
    "start:server": "node packages/sniper-api/server.js",
    "backup": "node bin/backup-volume.js",
    "test": "node --test packages/sniper-api/*.test.js tests/hooks/*.test.js tests/auto-contextualization/**/*.test.js tests/context-registry/*.test.js && npm run test:ws",
    "test:ws": "node --import tsx --test tests/websocket/Broadcaster.test.ts",
    "audit:verify": "node bin/kairos.js audit:verify",
    "compliance:purge": "node bin/kairos.js compliance:purge",
    "lint": "eslint .claude/hooks .aiox/task-discovery.js tests/hooks --quiet",
    "lint:all": "eslint .",
    "build": "npm run typecheck && npm run kairos:web:build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "kairos:hyperdrive": "node packages/hyperdrive/src/cli.js",
    "kairos:ledger:verify": "node packages/hyperdrive/src/memory/ledger.js --verify",
    "kairos:kg:progress": "node packages/hyperdrive/src/memory/knowledge-graph.js --progress",
    "kairos:hyper-diagnose": "node scripts/hyperdrive/hyper-diagnose.js",
    "kairos:validate": "node scripts/hyperdrive/isolated-validate.js",
    "kairos:infra-lock": "node scripts/hyperdrive/infra-lock.js",
    "kairos:web:dev": "npm run dev --prefix packages/web",
    "kairos:web:build": "npm run build --prefix packages/web",
    "kairos:overnight": "node scripts/run-overnight.js",
    "kairos:orion": "node scripts/orion-watch.js",
    "kairos:consolidate": "node scripts/consolidate.js",
    "kairos:calibrate": "node scripts/calibrate.js",
    "kairos:patterns": "node scripts/patterns.js",
    "kairos:health": "node scripts/health.js",
    "kairos:costs": "node scripts/costs.js",
    "kairos:export": "node scripts/export.js",
    "sync:ide:claude": "node .aiox-core/infrastructure/scripts/ide-sync/index.js sync --ide claude-code",
    "validate:claude-sync": "node .aiox-core/infrastructure/scripts/ide-sync/index.js validate --ide claude-code",
    "validate:claude-integration": "node .aiox-core/infrastructure/scripts/validate-claude-integration.js",
    "prepare": "husky"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "resend": "^6.12.3",
    "stripe": "^16.0.0",
    "ws": "^8.21.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.1",
    "tsx": "^4.22.4"
  }
}
