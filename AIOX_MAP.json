  "workflows": {
    "primary": [
      {
        "id": "sdc",
        "name": "Story Development Cycle",
        "description": "Full 5-phase flow for all development",
        "phases": [
          {
            "phase": 1,
            "name": "Create",
            "agent": "@sm",
            "task": "create-next-story.md",
            "input": "PRD, epic context",
            "output": "story.md (Draft)",
            "command": "*draft"
          },
          {
            "phase": 2,
            "name": "Validate",
            "agent": "@po",
            "task": "validate-next-story.md",
            "checklist": "10-point validation",
            "decisions": [
              "GO (>=7/10) -> Ready",
              "NO-GO -> fixes required"
            ],
            "command": "*validate-story-draft"
          },
          {
            "phase": 3,
            "name": "Implement",
            "agent": "@dev",
            "task": "dev-develop-story.md",
            "modes": [
              "YOLO (autonomous)",
              "Interactive (default)",
              "Pre-Flight (plan-first)"
            ],
            "transitions": [
              "Ready -> InProgress",
              "InProgress -> InReview"
            ],
            "coderabbit": "max 2 iterations self-healing",
            "command": "*develop"
          },
          {
            "phase": 4,
            "name": "QA Gate",
            "agent": "@qa",
            "task": "qa-gate.md",
            "checks": 7,
            "verdicts": [
              "PASS -> Done",
              "CONCERNS -> Done (with notes)",
              "FAIL -> InProgress (back to @dev)",
              "WAIVED -> Done (rare)"
            ],
            "command": "*qa-gate"
          },
          {
            "phase": 5,
            "name": "Push",
            "agent": "@devops",
            "task": "github-devops-pre-push-quality-gate.md",
            "requirement": "QA PASS/CONCERNS/WAIVED only",
            "actions": [
              "git push",
              "gh pr create",
              "release management (if applicable)"
            ],
            "command": "*push"
          }
        ]
      },
      {
        "id": "qa-loop",
        "name": "QA Loop — Iterative Review-Fix",
        "description": "Self-healing review cycle with auto-escalation",
        "flow": "@qa review -> @dev fixes -> re-review (max 5)",
        "escalation_triggers": [
          "max_iterations_reached (5)",
          "verdict_blocked",
          "fix_failure",
          "manual_escalate"
        ]
      },
      {
        "id": "spec-pipeline",
        "name": "Spec Pipeline — Pre-Implementation Requirements",
        "description": "Transform informal requirements to executable spec",
        "complexity_classes": {
          "simple": {
            "score": "<=8",
            "phases": 3,
            "gate": "Gather -> Write Spec -> Critique"
          },
          "standard": {
            "score": "9-15",
            "phases": 6,
            "gate": "All phases"
          },
          "complex": {
            "score": ">=16",
            "phases": 7,
            "gate": "6 phases + revision cycle"
          }
        },
        "constitutional_gate": "Article IV: No Invention — Every statement MUST trace to FR-*, NFR-*, CON-* or research"
      },
