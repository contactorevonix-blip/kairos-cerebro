# ────────────────────────────────────────────────────────────
# KAIROS — Web Environment Variables
# Copy to .env.local and fill in your values
# ────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Database (PostgreSQL) ─────────────────────────────────────────
# Get one free at: neon.tech or supabase.com
DATABASE_URL=postgresql://user:password@host:5432/kairos

# ── Auth (NextAuth v5) ───────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=your_random_secret_here
AUTH_URL=http://localhost:3000

# ── Email (Resend — for magic links) ───────────────────────────
# Get API key at: resend.com
RESEND_API_KEY=re_xxxx
EMAIL_FROM=KAIROS <noreply@kairos.app>

# ── Stripe ──────────────────────────────────────────────────
# dashboard.stripe.com > Developers > API keys
STRIPE_SECRET_KEY=sk_test_xxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx

# Webhook secret (stripe listen --forward-to localhost:3000/api/stripe/webhook)
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# Stripe Price IDs (create in Stripe dashboard > Products)
# One-time token packs
STRIPE_PRICE_TOKENS_100=price_xxxx
STRIPE_PRICE_TOKENS_500=price_xxxx
STRIPE_PRICE_TOKENS_2000=price_xxxx
STRIPE_PRICE_TOKENS_10000=price_xxxx
# Recurring subscriptions
STRIPE_PRICE_PRO=price_xxxx
STRIPE_PRICE_ENTERPRISE=price_xxxx
