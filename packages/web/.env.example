# ─────────────────────────────────────────────────────────────────
# KAIROS Web — environment variables
# Copy to .env.local and fill in the values
# ─────────────────────────────────────────────────────────────────

# Public URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database (Neon / Supabase / Railway PostgreSQL) ───────────────
DATABASE_URL=postgresql://user:password@host:5432/kairos

# ── Auth (NextAuth v5) ────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# ── Email (Resend) ────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=KAIROS <noreply@yourdomain.com>

# ── Stripe ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Price IDs from your Stripe dashboard (Products → Prices)
STRIPE_PRICE_TOKENS_100=price_xxxxxxxxxxxx
STRIPE_PRICE_TOKENS_500=price_xxxxxxxxxxxx
STRIPE_PRICE_TOKENS_2000=price_xxxxxxxxxxxx
STRIPE_PRICE_TOKENS_10000=price_xxxxxxxxxxxx
STRIPE_PRICE_PRO=price_xxxxxxxxxxxx
STRIPE_PRICE_ENTERPRISE=price_xxxxxxxxxxxx

# ── Sniper Engine (optional) ──────────────────────────────────────
# When set, /api/check proxies to the real sniper-api service.
# Leave blank to use the built-in local heuristic fallback.
# Example: http://localhost:4000  or  https://api.yourdomain.com
SNIPER_API_URL=
