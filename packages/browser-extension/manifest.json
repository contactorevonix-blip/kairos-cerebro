{
  "manifest_version": 3,
  "name": "KAIROS — Anti-Fraud Shield",
  "short_name": "KAIROS Shield",
  "version": "0.2.0",
  "description": "Real-time fraud detection on every page, checkout and link. Powered by KAIROS 8-layer engine.",
  "permissions": ["activeTab", "storage", "scripting", "tabs"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "action": {
    "default_title": "KAIROS Shield",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "exclude_matches": ["chrome://*/*", "chrome-extension://*/*"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
