{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AIOX Task Registry",
  "description": "Schema for the auto-discovered AIOX task registry (Story 1.17 — Task-First Automation). Generated by .aiox-core/development/tasks/task-discovery.js.",
  "type": "object",
  "required": ["generatedAt", "taskCount", "tasks"],
  "properties": {
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO timestamp of when the registry was built."
    },
    "sourceDir": {
      "type": "string",
      "description": "Directory scanned for task .md files."
    },
    "taskCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of indexed tasks."
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "file", "category", "triggers"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Stable task identifier (kebab-case filename without extension)."
          },
          "name": {
            "type": "string",
            "description": "Human-readable task name (from first H1 heading or derived from id)."
          },
          "file": {
            "type": "string",
            "description": "Relative path to the task .md file."
          },
          "category": {
            "type": "string",
            "enum": ["feature", "bug", "refactor", "arch", "config", "docs", "db", "qa", "devops", "general"],
            "description": "Inferred or declared task category."
          },
          "triggers": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["story-start", "code-review", "pre-commit", "workflow-phase", "manual"]
            },
            "description": "Contexts in which this task is relevant."
          },
          "agent": {
            "type": "string",
            "description": "Default executing agent (e.g. @dev, @qa), when declared."
          },
          "keywords": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Keywords extracted for relevance matching."
          },
          "automated": {
            "type": "boolean",
            "description": "Whether the task may run without manual invocation."
          },
          "interactive": {
            "type": "boolean",
            "description": "Whether the task requires user prompts."
          }
        }
      }
    }
  }
}
