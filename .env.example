# =============================================================================
# Kairos Check — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values for local development.
# DO NOT commit .env with real credentials.
#
# Production secrets are NEVER stored here — they live in:
#   - Bitwarden vault (source of truth + rotation history)
#   - Railway dashboard (operational projection — runtime)
#   - GitHub Secrets (devops tokens for CI/CD)
#
# Reference: docs/operations/secrets-runbook.md
# =============================================================================


# =============================================================================
# RAILWAY RUNTIME — 10 mandatory + 3 optional + 2 conditional
# =============================================================================
# These variables MUST be configured in the Railway dashboard for the
# `kairos-api` service. Locally, they can stay at the defaults shown below.

# --- Core (mandatory) -----------------------------------------------------
NODE_ENV=production
PORT=8787

KAIROS_DB_DIR=./.kairos-data
KAIROS_VAULT_DIR=./.kairos-data

# APOCALYPTIC — never lose. See secrets-runbook §2 + §5.1.
KAIROS_MASTER_PASSPHRASE=

# APOCALYPTIC — NEVER ROTATE. Rotating breaks every GDPR pseudonym in the audit trail.
KAIROS_PII_SALT=

KAIROS_PUBLIC_BASE_URL=https://kairoscheck.net

# Admin token — protege /dashboard e /api/admin/*. Gera com: openssl rand -hex 32
KAIROS_ADMIN_TOKEN=

# Demo API key — usado em exemplos e documentação. Gera com: openssl rand -hex 16
KAIROS_DEMO_KEY=demo_key_placeholder

# GDPR Art. 5(1)(e) storage limitation. Default 90.
KAIROS_RETENTION_DAYS=90

# Reputation graph backend (json | redis). Fase 2 default = json.
KAIROS_RG_ADAPTER=json
KAIROS_RG_NAMESPACE=default

# --- Optional hardening (sensible defaults applied if unset) ---------------
KAIROS_PUBLIC_RATE_PER_MIN=10
KAIROS_PUBLIC_VERIFY_MAX_CHARS=16000
KAIROS_VERIFY_BATCH_MAX=50

# --- Conditional (set iff KAIROS_RG_ADAPTER=redis) -------------------------
# In Railway use the reference variable: ${{ kairos-redis.REDIS_URL }}
KAIROS_REDIS_URL=
KAIROS_RG_REPLICATE_REDIS=0


# =============================================================================
# RAILWAY BILLING — 7 mandatory
# =============================================================================

# Stripe live secret key — sk_live_... — Stripe Dashboard → Developers → API Keys.
# CRITICAL secret. See secrets-runbook §5.2.
STRIPE_SECRET_KEY=

# Mode flag — `live` in production, `test` locally.
STRIPE_MODE=test

# CRITICAL — Stripe webhook HMAC. Created in Fase 2.5 after registering the endpoint.
# Format: whsec_...
KAIROS_STRIPE_WEBHOOK_SECRET=

# Stripe price IDs — Stripe Dashboard → Products. NOT secret — published in /api/billing/plans.
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_SCALE=

# Transactional email — re_... — https://resend.com. SENSITIVE. See secrets-runbook §5.4.
RESEND_API_KEY=


# =============================================================================
# RAILWAY MONITORING — 1 optional
# =============================================================================

# Sentry DSN — activated in Fase 2.8. SENSITIVE. No-op if unset.
SENTRY_DSN=


# =============================================================================
# LOCAL DEV / CLI — NOT on Railway
# =============================================================================

# kairos-cli pointing at a local or remote API. Developer machine only.
KAIROS_API_BASE=http://127.0.0.1:8787
KAIROS_API_KEY=

# Temporary, during `kairos vault:rotate` only. Never persist.
KAIROS_NEW_MASTER_PASSPHRASE=

# Legacy Stripe webhook fallback — DO NOT SET. Canonical is KAIROS_STRIPE_WEBHOOK_SECRET.
# Documented for back-compat awareness only.
# STRIPE_WEBHOOK_SECRET=


# =============================================================================
# DEVOPS TOKENS — GitHub Secrets, NOT Railway
# =============================================================================
# These power CI/CD, backups, and infra automation. Storage = GitHub Secrets
# (for workflows) + Bitwarden (master copy). Never paste into Railway.

# Railway CLI / API token — used by .github/workflows/deploy.yml
RAILWAY_TOKEN=

# Cloudflare R2 (Fase 2.3.bis — volume backup → R2 bucket)
R2_BACKUP_BUCKET=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# GitHub fine-grained PAT (only if used for cross-repo actions)
GITHUB_TOKEN=


# =============================================================================
# LOCAL DEVOPS / CLAUDE CODE — Developer machine, NOT runtime
# =============================================================================
# These power the dev environment (agents, MCPs, AIOX). They never reach
# the production API server.

# LLM providers
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Search & research MCPs
EXA_API_KEY=
CONTEXT7_API_KEY=

# AIOX-related (optional, for upstream tooling)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Project management
CLICKUP_API_KEY=

# Automation & workflows
N8N_API_KEY=
N8N_WEBHOOK_URL=

# Other deploy targets (not used in Fase 2)
VERCEL_TOKEN=

# AIOX framework version pin
AIOX_VERSION=2.2.0
