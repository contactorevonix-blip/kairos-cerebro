# ============================================
# Kairos Check — Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env with real credentials.
# ============================================


# === RUNTIME ===
NODE_ENV=production
PORT=8787

# Persistence (DB + audit chain + sovereign decisions)
KAIROS_DB_DIR=./.kairos-data

# Vault (AES-256-GCM secret store)
KAIROS_VAULT_DIR=./.kairos-data
KAIROS_MASTER_PASSPHRASE=
KAIROS_NEW_MASTER_PASSPHRASE=

# Public landing / sitemap / robots / canonical URLs
KAIROS_PUBLIC_BASE_URL=https://kairoscheck.net

# Public verify endpoint hardening
KAIROS_PUBLIC_RATE_PER_MIN=10
KAIROS_PUBLIC_VERIFY_MAX_CHARS=16000
KAIROS_VERIFY_BATCH_MAX=50

# GDPR / compliance
KAIROS_RETENTION_DAYS=90
KAIROS_PII_SALT=

# Reputation graph backend (json | redis)
KAIROS_RG_ADAPTER=json
KAIROS_REDIS_URL=
KAIROS_RG_NAMESPACE=default
KAIROS_RG_REPLICATE_REDIS=0

# CLI client defaults (kairos-cli pointing at local API)
KAIROS_API_BASE=http://127.0.0.1:8787
KAIROS_API_KEY=


# === BILLING ===
# Stripe (live secret key — get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=
STRIPE_MODE=test

# Stripe webhook HMAC verification (KAIROS_* takes precedence, STRIPE_* is fallback)
KAIROS_STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_SECRET=

# Stripe price IDs — map to tiers
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_SCALE=

# Transactional email (https://resend.com)
RESEND_API_KEY=


# === INTEGRATIONS ===

# LLM providers
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Search & research
EXA_API_KEY=
CONTEXT7_API_KEY=

# Database / backend (optional, for AIOX tooling)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Version control & CI/CD
GITHUB_TOKEN=

# Project management
CLICKUP_API_KEY=

# Automation & workflows
N8N_API_KEY=
N8N_WEBHOOK_URL=

# Monitoring & analytics
SENTRY_DSN=

# Cloud providers (deployment)
RAILWAY_TOKEN=
VERCEL_TOKEN=

# AIOX framework
AIOX_VERSION=2.2.0
